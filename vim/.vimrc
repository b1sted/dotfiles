set nocompatible
syntax on
filetype plugin indent on

set number
set mouse=a
set encoding=utf-8
set noswapfile

set tabstop=4
set shiftwidth=4
set expandtab
set autoindent
set smartindent

set hlsearch
set incsearch
set ignorecase
set smartcase

set wildmenu
set laststatus=2
set scrolloff=8
set backspace=indent,eol,start
